{
  "info": {
    "name": "Fluxo Completo - Video Processor (via Gateway)",
    "description": "Collection para testar o fluxo completo via API Gateway.\n\nUse uma environment com a variável {{host}} (por exemplo, http://localhost:8080).\n\nFluxo típico:\n1) Registrar usuário\n2) Login (salva {{token}})\n3) (Opcional) Get User / Validate Token\n4) Upload de vídeo (usa {{token}} e {{videoUserId}})\n5) Listar vídeos e buscar por ID\n6) Acompanhar processamento assíncrono (RabbitMQ + video-service).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "host", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "videoUserId", "value": "" },
    { "key": "videoId", "value": "" },
    { "key": "videoFilePath", "value": "", "description": "Caminho do vídeo para Upload" },
    { "key": "page", "value": "0" },
    { "key": "size", "value": "10" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "url": "{{host}}/actuator/health",
            "description": "Health check do API Gateway."
          }
        },
        {
          "name": "Video Service Health (via gateway)",
          "request": {
            "method": "GET",
            "url": "{{host}}/api/videos/health",
            "description": "Health check do video-service via gateway."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_user\",\n  \"email\": \"postman@example.com\",\n  \"password\": \"senha123\"\n}"
            },
            "url": "{{host}}/api/auth/register",
            "description": "Registra novo usuário via gateway. 201 + UserResponse (id, userUuid, username, email, enabled). Salva userId e videoUserId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.id) pm.collectionVariables.set('userId', json.id);",
                  "  if (json.userUuid) pm.collectionVariables.set('videoUserId', json.userUuid);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_user\",\n  \"password\": \"senha123\"\n}"
            },
            "url": "{{host}}/api/auth/login",
            "description": "Login via gateway. 200 + token, type, expiresIn, username. Salva token para rotas protegidas."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "url": "{{host}}/api/auth/validate?token={{token}}",
            "description": "Valida o JWT via gateway (rota pública). 200 + valid, subject."
          }
        },
        {
          "name": "Get User by Id (protegido)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{host}}/api/auth/users/{{userId}}",
            "description": "Retorna usuário por id. 200 + id, userUuid, username, email, enabled. Atualiza videoUserId se a resposta tiver userUuid."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.userUuid) pm.collectionVariables.set('videoUserId', json.userUuid);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Videos",
      "item": [
        {
          "name": "List Videos",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{host}}/api/videos?userId={{videoUserId}}&page={{page}}&size={{size}}",
              "host": ["{{host}}"],
              "path": ["api", "videos"],
              "query": [
                { "key": "userId", "value": "{{videoUserId}}" },
                { "key": "page", "value": "{{page}}" },
                { "key": "size", "value": "{{size}}" }
              ]
            },
            "description": "Lista vídeos do usuário (paginação). Exige token. {{videoUserId}} deve ser um UUID."
          }
        },
        {
          "name": "Get Video by Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{host}}/api/videos/{{videoId}}",
            "description": "Busca vídeo por UUID. Exige token. Defina {{videoId}} com o id retornado ao listar ou criar."
          }
        },
        {
          "name": "Upload Video",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "X-User-Id", "value": "{{videoUserId}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "{{videoFilePath}}",
                  "description": "Defina {{videoFilePath}} na collection ou selecione o arquivo manualmente."
                }
              ]
            },
            "url": "{{host}}/api/videos",
            "description": "Upload de vídeo (multipart). Exige token e header X-User-Id (UUID). 202 Accepted."
          }
        }
      ]
    },
    {
      "name": "Erros de exemplo",
      "item": [
        {
          "name": "Register (duplicata - 400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_user\",\n  \"email\": \"outro@example.com\",\n  \"password\": \"senha123\"\n}"
            },
            "url": "{{host}}/api/auth/register",
            "description": "Mesmo username já existente. Esperado 400."
          }
        },
        {
          "name": "Login (senha errada - 401)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_user\",\n  \"password\": \"senha_errada\"\n}"
            },
            "url": "{{host}}/api/auth/login",
            "description": "Credenciais inválidas. Esperado 401."
          }
        },
        {
          "name": "Get User sem token (401)",
          "request": {
            "method": "GET",
            "url": "{{host}}/api/auth/users/{{userId}}",
            "description": "Sem header Authorization. Esperado 401 (gateway)."
          }
        }
      ]
    }
  ]
}


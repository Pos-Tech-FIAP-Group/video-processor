{
  "info": {
    "name": "Auth Service - Video Processor",
    "description": "Endpoints do Auth Service (porta 8081). Acesso direto ao serviço; para uso via gateway use a collection do API Gateway.\n\nVariáveis: baseUrl (http://localhost:8081), token, userId (id Mongo para Get User), videoUserId (UUID = userUuid para X-User-Id no video-service).\n\nPúblicos: register, login, validate (query token=), actuator.\nProtegidos (Authorization: Bearer <token>): users/{id}.\nRota interna (sem JWT): GET /internal/users/by-uuid/{uuid} — usada pelo notification-service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "videoUserId", "value": "" }
  ],
  "item": [
    {
      "name": "Públicos",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_user\",\n  \"email\": \"postman@example.com\",\n  \"password\": \"senha123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Registra novo usuário. 201 + UserResponse (id, userUuid, username, email, enabled). Salva userId e videoUserId (userUuid para video-service)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (json.id) pm.collectionVariables.set('userId', json.id);",
                  "  if (json.userUuid) pm.collectionVariables.set('videoUserId', json.userUuid);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_user\",\n  \"password\": \"senha123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Login. 200 + token, type, expiresIn (ms), username, userId, userUuid. Salva token, userId e videoUserId (userUuid) para rotas protegidas e para uso no video-service."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.token) pm.collectionVariables.set('token', json.token);",
                  "  if (json.userId) pm.collectionVariables.set('userId', json.userId);",
                  "  if (json.userUuid) pm.collectionVariables.set('videoUserId', json.userUuid);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Validate Token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/validate?token={{token}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "validate"],
              "query": [{ "key": "token", "value": "{{token}}" }]
            },
            "description": "Valida o JWT (rota pública). Token via query param. 200 + valid, subject."
          }
        },
        {
          "name": "Actuator Health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/actuator/health",
            "description": "Health check. Público, não exige token."
          }
        }
      ]
    },
    {
      "name": "Protegidos (exigem token)",
      "item": [
        {
          "name": "Get User by Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/auth/users/{{userId}}",
            "description": "Retorna usuário por id. 200 + id, userUuid, username, email, enabled. Atualiza videoUserId se a resposta tiver userUuid."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.userUuid) pm.collectionVariables.set('videoUserId', json.userUuid);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Exemplos de erro",
      "item": [
        {
          "name": "Register (duplicata - 400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_user\",\n  \"email\": \"outro@example.com\",\n  \"password\": \"senha123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Mesmo username já existente. Esperado 400."
          }
        },
        {
          "name": "Login (senha errada - 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"postman_user\",\n  \"password\": \"senha_errada\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Credenciais inválidas. Esperado 401."
          }
        },
        {
          "name": "Get User sem token (403)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/users/{{userId}}",
            "description": "Sem header Authorization. Esperado 401 (ou 403 conforme Spring Security)."
          }
        }
      ]
    },
    {
      "name": "Rota interna (service-to-service)",
      "item": [
        {
          "name": "Get User by UUID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/internal/users/by-uuid/{{videoUserId}}",
            "description": "Busca usuário por UUID. Rota interna (não exposta no gateway); sem JWT. Usada pelo notification-service. 200 + id, userUuid, username, email, enabled. Execute Register ou Login antes para ter videoUserId."
          }
        }
      ]
    }
  ]
}
